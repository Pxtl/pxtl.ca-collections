<Project Sdk="Microsoft.NET.Sdk">

  <Import Project="Version.props" />

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <LangVersion>12.0</LangVersion>
    <Nullable>enable</Nullable>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
    <WarningLevel>4</WarningLevel>
    <ImplicitUsings>enable</ImplicitUsings>
    <NoWarn>$(NoWarn);1591</NoWarn>    
  </PropertyGroup>

  <PropertyGroup>
    <ProjectGuid>668de199-9787-4f1c-b3cb-c0a5cf9732a7</ProjectGuid>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <Packagedoc>README.md</Packagedoc>
    <PackageId>PxtlCa.Collections</PackageId>
    <Authors>Martin Zarate (AKA Pxtl)</Authors>
    <Description>
      Custom collections for .NET Standard 2.0.  Includes overrideable virtual
      wrappers for Dictionary and List and various utility-versions of
      Dictionary.
    </Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/Pxtl/pxtl.ca-collections</PackageProjectUrl>
    <RepositoryUrl>$(PackageProjectUrl)</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>netstandard2.0 collections filters virtual overrideable</PackageTags>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <!-- coding standards -->
  <PropertyGroup>
    <EnableNETAnalyzers>true</EnableNETAnalyzers>
    <RunAnalyzersDuringBuild>true</RunAnalyzersDuringBuild>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Collections" Version="4.3.0" />
    <PackageReference Include="System.Linq" Version="4.3.0" />
  </ItemGroup>

  <ItemGroup>
    <None Include="../README.md" Pack="True" PackagePath="" />
    <None Include="../LICENSE" Pack="True" PackagePath="" />
  </ItemGroup>

</Project>
